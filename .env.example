API_KEY=your-secret-api-key-here
PORT=3000

# Browserless.io (required for scraping)
BROWSERLESS_TOKEN=your-browserless-api-token
# Optional overrides (defaults: production-sfo.browserless.io /chromium)
# BROWSERLESS_WS_HOST=production-sfo.browserless.io
# BROWSERLESS_WS_PATH=/chromium

# Upstash Redis (required on Vercel for async job polling; add via Vercel Marketplace)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names also supported:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
